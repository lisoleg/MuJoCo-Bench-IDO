<mujoco model="humanoid_ramp_arena">
  <option timestep="0.005" gravity="0 0 -9.81"/>

  <default>
    <joint damping="0.5" armature="0.1"/>
    <geom friction="1.0 0.5 0.5" condim="3" contype="1" conaffinity="1"/>
    <motor ctrlrange="-1 1" ctrllimited="true"/>
  </default>

  <asset>
    <texture type="skybox" builtin="gradient" rgb1="0.3 0.5 0.7" rgb2="0.1 0.2 0.4" width="512" height="512"/>
    <texture name="grid_tex" type="2d" builtin="checker" rgb1="0.2 0.3 0.4" rgb2="0.15 0.25 0.35" width="512" height="512" mark="none" markrgb="0.4 0.6 0.8"/>
    <material name="grid_mat" texture="grid_tex" texrepeat="12 12" reflectance="0.2"/>
    <material name="ramp_mat" rgba="0.7 0.4 0.2 1" reflectance="0.2"/>
    <material name="block_mat" rgba="0.4 0.6 0.3 1" reflectance="0.1"/>
    <material name="target_mat" rgba="1 0.1 0.1 1" reflectance="0.5"/>
    <material name="body_mat" rgba="0.8 0.6 0.4 1"/>
  </asset>

  <worldbody>
    <!-- Ground plane -->
    <geom name="ground" type="plane" size="12 12 0.1" material="grid_mat" contype="1" conaffinity="1"/>
    <light directional="true" pos="0 0 5" dir="0 0 -1" diffuse="0.8 0.8 0.8" specular="0.3 0.3 0.3"/>

    <!-- Inclined ramp: 4m long, 0.4m rise, centered at x=3 -->
    <body name="ramp" pos="3 0 0.2" quat="0.995 0 -0.1 0">
      <geom name="ramp_geom" type="box" size="2.0 1.5 0.1" material="ramp_mat" mass="1000" contype="1" conaffinity="3"/>
    </body>

    <!-- Side blocks to channel movement -->
    <body name="block_left" pos="-2 4 0.3">
      <geom name="block_left_geom" type="box" size="1.5 0.2 0.3" material="block_mat" mass="1000" contype="1" conaffinity="3"/>
    </body>
    <body name="block_right" pos="-2 -4 0.3">
      <geom name="block_right_geom" type="box" size="1.5 0.2 0.3" material="block_mat" mass="1000" contype="1" conaffinity="3"/>
    </body>

    <!-- Target marker -->
    <body name="target_marker" pos="5 0 0.6">
      <geom name="target_geom" type="sphere" size="0.2" material="target_mat" contype="0" conaffinity="0"/>
    </body>

    <!-- Simplified Stick-figure Humanoid -->
    <body name="torso" pos="0 0 1.2">
      <joint name="root" type="free" damping="0.5"/>
      <geom name="torso_geom" type="capsule" size="0.06" fromto="0 0 0 0 0 0.4" material="body_mat" mass="5"/>
      <site name="torso_top" pos="0 0 0.4" size="0.01"/>

      <body name="head" pos="0 0 0.5">
        <joint name="head_joint" type="ball" damping="1" armature="0.2"/>
        <geom name="head_geom" type="sphere" size="0.08" material="body_mat" mass="1"/>
      </body>

      <body name="upper_leg_l" pos="0.05 0 -0.05">
        <joint name="hip_l" type="ball" damping="1" armature="0.2"/>
        <geom name="upper_leg_l_geom" type="capsule" size="0.04" fromto="0 0 0 0 0 -0.4" material="body_mat" mass="2"/>
        <body name="lower_leg_l" pos="0 0 -0.4">
          <joint name="knee_l" type="hinge" axis="0 1 0" damping="1" armature="0.2" range="-2.0 0.01"/>
          <geom name="lower_leg_l_geom" type="capsule" size="0.03" fromto="0 0 0 0 0 -0.4" material="body_mat" mass="1"/>
          <body name="foot_l" pos="0 0 -0.4">
            <joint name="ankle_l" type="hinge" axis="0 1 0" damping="0.5" armature="0.1" range="-0.5 0.5"/>
            <geom name="foot_l_geom" type="capsule" size="0.03 0.1" fromto="-0.05 0 0 0.1 0 0" material="body_mat" mass="0.5"/>
            <site name="foot_l_site" pos="0 0 0" size="0.01"/>
          </body>
        </body>
      </body>

      <body name="upper_leg_r" pos="-0.05 0 -0.05">
        <joint name="hip_r" type="ball" damping="1" armature="0.2"/>
        <geom name="upper_leg_r_geom" type="capsule" size="0.04" fromto="0 0 0 0 0 -0.4" material="body_mat" mass="2"/>
        <body name="lower_leg_r" pos="0 0 -0.4">
          <joint name="knee_r" type="hinge" axis="0 1 0" damping="1" armature="0.2" range="-2.0 0.01"/>
          <geom name="lower_leg_r_geom" type="capsule" size="0.03" fromto="0 0 0 0 0 -0.4" material="body_mat" mass="1"/>
          <body name="foot_r" pos="0 0 -0.4">
            <joint name="ankle_r" type="hinge" axis="0 1 0" damping="0.5" armature="0.1" range="-0.5 0.5"/>
            <geom name="foot_r_geom" type="capsule" size="0.03 0.1" fromto="-0.05 0 0 0.1 0 0" material="body_mat" mass="0.5"/>
            <site name="foot_r_site" pos="0 0 0" size="0.01"/>
          </body>
        </body>
      </body>

      <body name="upper_arm_l" pos="0.15 0 0.35">
        <joint name="shoulder_l" type="ball" damping="1" armature="0.1"/>
        <geom name="upper_arm_l_geom" type="capsule" size="0.03" fromto="0 0 0 0.2 0 -0.25" material="body_mat" mass="1"/>
        <body name="lower_arm_l" pos="0.2 0 -0.25">
          <joint name="elbow_l" type="hinge" axis="0 1 0" damping="0.5" armature="0.1" range="-2.5 0"/>
          <geom name="lower_arm_l_geom" type="capsule" size="0.025" fromto="0 0 0 0.15 0 -0.2" material="body_mat" mass="0.5"/>
        </body>
      </body>

      <body name="upper_arm_r" pos="-0.15 0 0.35">
        <joint name="shoulder_r" type="ball" damping="1" armature="0.1"/>
        <geom name="upper_arm_r_geom" type="capsule" size="0.03" fromto="0 0 0 -0.2 0 -0.25" material="body_mat" mass="1"/>
        <body name="lower_arm_r" pos="-0.2 0 -0.25">
          <joint name="elbow_r" type="hinge" axis="0 1 0" damping="0.5" armature="0.1" range="-2.5 0"/>
          <geom name="lower_arm_r_geom" type="capsule" size="0.025" fromto="0 0 0 -0.15 0 -0.2" material="body_mat" mass="0.5"/>
        </body>
      </body>
    </body>
  </worldbody>

  <actuator>
    <general name="head_x" joint="head_joint" gear="0 0 0 1 0 0" gainprm="0.1" ctrlrange="-1 1"/>
    <general name="head_y" joint="head_joint" gear="0 0 0 0 1 0" gainprm="0.1" ctrlrange="-1 1"/>
    <general name="head_z" joint="head_joint" gear="0 0 0 0 0 1" gainprm="0.1" ctrlrange="-1 1"/>
    <general name="hip_l_x" joint="hip_l" gear="0 0 0 1 0 0" gainprm="1" ctrlrange="-1 1"/>
    <general name="hip_l_y" joint="hip_l" gear="0 0 0 0 1 0" gainprm="1" ctrlrange="-1 1"/>
    <general name="hip_l_z" joint="hip_l" gear="0 0 0 0 0 1" gainprm="1" ctrlrange="-1 1"/>
    <general name="hip_r_x" joint="hip_r" gear="0 0 0 1 0 0" gainprm="1" ctrlrange="-1 1"/>
    <general name="hip_r_y" joint="hip_r" gear="0 0 0 0 1 0" gainprm="1" ctrlrange="-1 1"/>
    <general name="hip_r_z" joint="hip_r" gear="0 0 0 0 0 1" gainprm="1" ctrlrange="-1 1"/>
    <motor name="knee_l" joint="knee_l" gear="1" ctrlrange="-1 1"/>
    <motor name="knee_r" joint="knee_r" gear="1" ctrlrange="-1 1"/>
    <general name="ankle_l" joint="ankle_l" gear="0 0 0 0 1 0" gainprm="0.5" ctrlrange="-1 1"/>
    <general name="ankle_r" joint="ankle_r" gear="0 0 0 0 1 0" gainprm="0.5" ctrlrange="-1 1"/>
    <general name="shoulder_l_x" joint="shoulder_l" gear="0 0 0 1 0 0" gainprm="0.5" ctrlrange="-1 1"/>
    <general name="shoulder_l_y" joint="shoulder_l" gear="0 0 0 0 1 0" gainprm="0.5" ctrlrange="-1 1"/>
    <general name="shoulder_l_z" joint="shoulder_l" gear="0 0 0 0 0 1" gainprm="0.5" ctrlrange="-1 1"/>
    <general name="shoulder_r_x" joint="shoulder_r" gear="0 0 0 1 0 0" gainprm="0.5" ctrlrange="-1 1"/>
    <general name="shoulder_r_y" joint="shoulder_r" gear="0 0 0 0 1 0" gainprm="0.5" ctrlrange="-1 1"/>
    <general name="shoulder_r_z" joint="shoulder_r" gear="0 0 0 0 0 1" gainprm="0.5" ctrlrange="-1 1"/>
    <general name="elbow_l" joint="elbow_l" gear="0 0 0 0 1 0" gainprm="0.3" ctrlrange="-1 1"/>
    <general name="elbow_r" joint="elbow_r" gear="0 0 0 0 1 0" gainprm="0.3" ctrlrange="-1 1"/>
  </actuator>

  <contact>
    <exclude body1="torso" body2="upper_leg_l"/>
    <exclude body1="torso" body2="upper_leg_r"/>
    <exclude body1="torso" body2="upper_arm_l"/>
    <exclude body1="torso" body2="upper_arm_r"/>
    <exclude body1="upper_leg_l" body2="lower_leg_l"/>
    <exclude body1="upper_leg_r" body2="lower_leg_r"/>
    <exclude body1="lower_leg_l" body2="foot_l"/>
    <exclude body1="lower_leg_r" body2="foot_r"/>
    <exclude body1="upper_arm_l" body2="lower_arm_l"/>
    <exclude body1="upper_arm_r" body2="lower_arm_r"/>
    <exclude body1="torso" body2="head"/>
  </contact>
</mujoco>
