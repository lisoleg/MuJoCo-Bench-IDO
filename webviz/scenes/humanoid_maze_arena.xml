<mujoco model="humanoid_maze_arena">
  <compiler angle="radian"/>
  <option timestep="0.005" gravity="0 0 -9.81" iterations="50" tolerance="1e-8"/>

  <default>
    <joint damping="0.5" armature="0.1"/>
    <geom friction="1.0 0.5 0.5" condim="3" contype="2" conaffinity="1"/>
    <motor ctrlrange="-1 1" ctrllimited="true"/>
  </default>

  <asset>
    <texture type="skybox" builtin="gradient" rgb1="0.3 0.5 0.7" rgb2="0.1 0.2 0.4" width="512" height="512"/>
    <texture name="grid_tex" type="2d" builtin="checker" rgb1="0.2 0.3 0.4" rgb2="0.15 0.25 0.35" width="512" height="512" mark="none" markrgb="0.4 0.6 0.8"/>
    <material name="grid_mat" texture="grid_tex" texrepeat="12 12" reflectance="0.2"/>
    <material name="wall_mat" rgba="0.55 0.35 0.25 1" reflectance="0.1"/>
    <material name="target_mat" rgba="1 0.1 0.1 1" reflectance="0.5"/>
    <material name="body_mat" rgba="0.8 0.6 0.4 1"/>
  </asset>

  <worldbody>
    <!-- Ground plane -->
    <geom name="ground" type="plane" size="12 12 0.1" material="grid_mat" contype="1" conaffinity="1"/>
    <light directional="true" pos="0 0 5" dir="0 0 -1" diffuse="0.8 0.8 0.8" specular="0.3 0.3 0.3"/>

    <!-- ─── Maze Walls ─── -->

    <!-- Outer boundary walls -->
    <body name="maze_wall_north" pos="0 6 0.4">
      <geom name="maze_wall_north_geom" type="box" size="6 0.15 0.4" material="wall_mat" mass="1000" contype="1" conaffinity="3" condim="4"/>
    </body>
    <body name="maze_wall_south" pos="0 -6 0.4">
      <geom name="maze_wall_south_geom" type="box" size="6 0.15 0.4" material="wall_mat" mass="1000" contype="1" conaffinity="3" condim="4"/>
    </body>
    <body name="maze_wall_east" pos="6 0 0.4">
      <geom name="maze_wall_east_geom" type="box" size="0.15 6 0.4" material="wall_mat" mass="1000" contype="1" conaffinity="3" condim="4"/>
    </body>
    <body name="maze_wall_west" pos="-6 0 0.4">
      <geom name="maze_wall_west_geom" type="box" size="0.15 6 0.4" material="wall_mat" mass="1000" contype="1" conaffinity="3" condim="4"/>
    </body>

    <!-- Internal maze walls — creating corridors and turns -->

    <!-- Wall A: Horizontal wall near start, blocks straight path -->
    <body name="maze_wall_a" pos="2 0 0.35">
      <geom name="maze_wall_a_geom" type="box" size="1.5 0.12 0.35" material="wall_mat" mass="1000" contype="1" conaffinity="3" condim="4"/>
    </body>

    <!-- Wall B: Vertical wall creating left turn -->
    <body name="maze_wall_b" pos="0 2.5 0.35">
      <geom name="maze_wall_b_geom" type="box" size="0.12 2 0.35" material="wall_mat" mass="1000" contype="1" conaffinity="3" condim="4"/>
    </body>

    <!-- Wall C: Horizontal wall in upper-left quadrant -->
    <body name="maze_wall_c" pos="-2 4 0.3">
      <geom name="maze_wall_c_geom" type="box" size="2.5 0.12 0.3" material="wall_mat" mass="1000" contype="1" conaffinity="3" condim="4"/>
    </body>

    <!-- Wall D: Vertical wall creating corridor -->
    <body name="maze_wall_d" pos="3.5 3 0.3">
      <geom name="maze_wall_d_geom" type="box" size="0.12 2.5 0.3" material="wall_mat" mass="1000" contype="1" conaffinity="3" condim="4"/>
    </body>

    <!-- Wall E: Short wall near target area -->
    <body name="maze_wall_e" pos="4.5 -2 0.25">
      <geom name="maze_wall_e_geom" type="box" size="1 0.12 0.25" material="wall_mat" mass="1000" contype="1" conaffinity="3" condim="4"/>
    </body>

    <!-- Wall F: Vertical wall creating dead-end branch -->
    <body name="maze_wall_f" pos="-3 -1.5 0.3">
      <geom name="maze_wall_f_geom" type="box" size="0.12 2.5 0.3" material="wall_mat" mass="1000" contype="1" conaffinity="3" condim="4"/>
    </body>

    <!-- ─── Target Marker (end of maze) ─── -->
    <body name="target_marker" pos="5 -4 0.2">
      <geom name="target_geom" type="sphere" size="0.2" material="target_mat" contype="0" conaffinity="0"/>
    </body>

    <!-- ─── Simplified Stick-figure Humanoid (hinge-only, motor actuator) ─── -->
    <body name="torso" pos="-4 4 1.2">
      <joint name="root" type="free" damping="0.5"/>
      <geom name="torso_geom" type="capsule" size="0.06" fromto="0 0 0 0 0 0.4" material="body_mat" mass="5" contype="2" conaffinity="1"/>
      <site name="torso_top" pos="0 0 0.4" size="0.01"/>

      <!-- Head: 3 serial hinge joints (replaces ball joint) -->
      <body name="head" pos="0 0 0.5">
        <joint name="head_x" type="hinge" axis="1 0 0" damping="1" armature="0.2" range="-0.5 0.5"/>
        <inertial pos="0 0 0" mass="0.001" diaginertia="1e-6 1e-6 1e-6"/>
        <body name="head_y_body" pos="0 0 0">
          <joint name="head_y" type="hinge" axis="0 1 0" damping="1" armature="0.2" range="-0.5 0.5"/>
        <inertial pos="0 0 0" mass="0.001" diaginertia="1e-6 1e-6 1e-6"/>
          <body name="head_z_body" pos="0 0 0">
            <joint name="head_z" type="hinge" axis="0 0 1" damping="1" armature="0.2" range="-0.5 0.5"/>
            <geom name="head_geom" type="sphere" size="0.08" material="body_mat" mass="1" contype="2" conaffinity="1"/>
          </body>
        </body>
      </body>

      <!-- Left leg: hip 3 serial hinge joints (replaces ball joint) -->
      <body name="upper_leg_l" pos="0.10 0 -0.05">
        <joint name="hip_l_x" type="hinge" axis="1 0 0" damping="1" armature="0.2" range="-1.2 1.2"/>
        <inertial pos="0 0 0" mass="0.001" diaginertia="1e-6 1e-6 1e-6"/>
        <body name="hip_l_y_body" pos="0 0 0">
          <joint name="hip_l_y" type="hinge" axis="0 1 0" damping="1" armature="0.2" range="-1.5 1.5"/>
        <inertial pos="0 0 0" mass="0.001" diaginertia="1e-6 1e-6 1e-6"/>
          <body name="hip_l_z_body" pos="0 0 0">
            <joint name="hip_l_z" type="hinge" axis="0 0 1" damping="1" armature="0.2" range="-1.0 1.0"/>
            <geom name="upper_leg_l_geom" type="capsule" size="0.04" fromto="0 0 0 0 0 -0.4" material="body_mat" mass="2" contype="2" conaffinity="1"/>

            <!-- Lower leg -->
            <body name="lower_leg_l" pos="0 0 -0.4">
              <joint name="knee_l" type="hinge" axis="0 1 0" damping="1" armature="0.2" range="-2.0 0.01"/>
              <geom name="lower_leg_l_geom" type="capsule" size="0.03" fromto="0 0 0 0 0 -0.4" material="body_mat" mass="1" contype="2" conaffinity="1"/>

              <!-- Foot -->
              <body name="foot_l" pos="0 0 -0.4">
                <joint name="ankle_l" type="hinge" axis="0 1 0" damping="0.5" armature="0.1" range="-0.5 0.5"/>
                <geom name="foot_l_geom" type="capsule" size="0.03 0.1" fromto="-0.05 0 0 0.1 0 0" material="body_mat" mass="0.5" contype="2" conaffinity="1"/>
                <site name="foot_l_site" pos="0 0 0" size="0.01"/>
              </body>
            </body>
          </body>
        </body>
      </body>

      <!-- Right leg: hip 3 serial hinge joints (replaces ball joint) -->
      <body name="upper_leg_r" pos="-0.10 0 -0.05">
        <joint name="hip_r_x" type="hinge" axis="1 0 0" damping="1" armature="0.2" range="-1.2 1.2"/>
        <inertial pos="0 0 0" mass="0.001" diaginertia="1e-6 1e-6 1e-6"/>
        <body name="hip_r_y_body" pos="0 0 0">
          <joint name="hip_r_y" type="hinge" axis="0 1 0" damping="1" armature="0.2" range="-1.5 1.5"/>
        <inertial pos="0 0 0" mass="0.001" diaginertia="1e-6 1e-6 1e-6"/>
          <body name="hip_r_z_body" pos="0 0 0">
            <joint name="hip_r_z" type="hinge" axis="0 0 1" damping="1" armature="0.2" range="-1.0 1.0"/>
            <geom name="upper_leg_r_geom" type="capsule" size="0.04" fromto="0 0 0 0 0 -0.4" material="body_mat" mass="2" contype="2" conaffinity="1"/>

            <!-- Lower leg -->
            <body name="lower_leg_r" pos="0 0 -0.4">
              <joint name="knee_r" type="hinge" axis="0 1 0" damping="1" armature="0.2" range="-2.0 0.01"/>
              <geom name="lower_leg_r_geom" type="capsule" size="0.03" fromto="0 0 0 0 0 -0.4" material="body_mat" mass="1" contype="2" conaffinity="1"/>

              <!-- Foot -->
              <body name="foot_r" pos="0 0 -0.4">
                <joint name="ankle_r" type="hinge" axis="0 1 0" damping="0.5" armature="0.1" range="-0.5 0.5"/>
                <geom name="foot_r_geom" type="capsule" size="0.03 0.1" fromto="-0.05 0 0 0.1 0 0" material="body_mat" mass="0.5" contype="2" conaffinity="1"/>
                <site name="foot_r_site" pos="0 0 0" size="0.01"/>
              </body>
            </body>
          </body>
        </body>
      </body>

      <!-- Left arm: shoulder 3 serial hinge joints (replaces ball joint) -->
      <body name="upper_arm_l" pos="0.15 0 0.35">
        <joint name="shoulder_l_x" type="hinge" axis="1 0 0" damping="1" armature="0.1" range="-1.5 1.5"/>
        <inertial pos="0 0 0" mass="0.001" diaginertia="1e-6 1e-6 1e-6"/>
        <body name="shoulder_l_y_body" pos="0 0 0">
          <joint name="shoulder_l_y" type="hinge" axis="0 1 0" damping="1" armature="0.1" range="-1.5 1.5"/>
        <inertial pos="0 0 0" mass="0.001" diaginertia="1e-6 1e-6 1e-6"/>
          <body name="shoulder_l_z_body" pos="0 0 0">
            <joint name="shoulder_l_z" type="hinge" axis="0 0 1" damping="1" armature="0.1" range="-1.5 1.5"/>
            <geom name="upper_arm_l_geom" type="capsule" size="0.03" fromto="0 0 0 0.2 0 -0.25" material="body_mat" mass="1" contype="2" conaffinity="1"/>

            <!-- Lower arm -->
            <body name="lower_arm_l" pos="0.2 0 -0.25">
              <joint name="elbow_l" type="hinge" axis="0 1 0" damping="0.5" armature="0.1" range="-2.5 0"/>
              <geom name="lower_arm_l_geom" type="capsule" size="0.025" fromto="0 0 0 0.15 0 -0.2" material="body_mat" mass="0.5" contype="2" conaffinity="1"/>
            </body>
          </body>
        </body>
      </body>

      <!-- Right arm: shoulder 3 serial hinge joints (replaces ball joint) -->
      <body name="upper_arm_r" pos="-0.15 0 0.35">
        <joint name="shoulder_r_x" type="hinge" axis="1 0 0" damping="1" armature="0.1" range="-1.5 1.5"/>
        <inertial pos="0 0 0" mass="0.001" diaginertia="1e-6 1e-6 1e-6"/>
        <body name="shoulder_r_y_body" pos="0 0 0">
          <joint name="shoulder_r_y" type="hinge" axis="0 1 0" damping="1" armature="0.1" range="-1.5 1.5"/>
        <inertial pos="0 0 0" mass="0.001" diaginertia="1e-6 1e-6 1e-6"/>
          <body name="shoulder_r_z_body" pos="0 0 0">
            <joint name="shoulder_r_z" type="hinge" axis="0 0 1" damping="1" armature="0.1" range="-1.5 1.5"/>
            <geom name="upper_arm_r_geom" type="capsule" size="0.03" fromto="0 0 0 -0.2 0 -0.25" material="body_mat" mass="1" contype="2" conaffinity="1"/>

            <!-- Lower arm -->
            <body name="lower_arm_r" pos="-0.2 0 -0.25">
              <joint name="elbow_r" type="hinge" axis="0 1 0" damping="0.5" armature="0.1" range="-2.5 0"/>
              <geom name="lower_arm_r_geom" type="capsule" size="0.025" fromto="0 0 0 -0.15 0 -0.2" material="body_mat" mass="0.5" contype="2" conaffinity="1"/>
            </body>
          </body>
        </body>
      </body>
    </body>
  </worldbody>

  <!-- Actuators: all motor type with gear for torque amplification -->
  <actuator>
    <motor name="act_head_x" joint="head_x" gear="20" ctrlrange="-1 1"/>
    <motor name="act_head_y" joint="head_y" gear="20" ctrlrange="-1 1"/>
    <motor name="act_head_z" joint="head_z" gear="20" ctrlrange="-1 1"/>
    <motor name="act_hip_l_x" joint="hip_l_x" gear="100" ctrlrange="-1 1"/>
    <motor name="act_hip_l_y" joint="hip_l_y" gear="100" ctrlrange="-1 1"/>
    <motor name="act_hip_l_z" joint="hip_l_z" gear="80" ctrlrange="-1 1"/>
    <motor name="act_hip_r_x" joint="hip_r_x" gear="100" ctrlrange="-1 1"/>
    <motor name="act_hip_r_y" joint="hip_r_y" gear="100" ctrlrange="-1 1"/>
    <motor name="act_hip_r_z" joint="hip_r_z" gear="80" ctrlrange="-1 1"/>
    <motor name="act_knee_l" joint="knee_l" gear="100" ctrlrange="-1 1"/>
    <motor name="act_knee_r" joint="knee_r" gear="100" ctrlrange="-1 1"/>
    <motor name="act_ankle_l" joint="ankle_l" gear="60" ctrlrange="-1 1"/>
    <motor name="act_ankle_r" joint="ankle_r" gear="60" ctrlrange="-1 1"/>
    <motor name="act_shoulder_l_x" joint="shoulder_l_x" gear="50" ctrlrange="-1 1"/>
    <motor name="act_shoulder_l_y" joint="shoulder_l_y" gear="50" ctrlrange="-1 1"/>
    <motor name="act_shoulder_l_z" joint="shoulder_l_z" gear="50" ctrlrange="-1 1"/>
    <motor name="act_shoulder_r_x" joint="shoulder_r_x" gear="50" ctrlrange="-1 1"/>
    <motor name="act_shoulder_r_y" joint="shoulder_r_y" gear="50" ctrlrange="-1 1"/>
    <motor name="act_shoulder_r_z" joint="shoulder_r_z" gear="50" ctrlrange="-1 1"/>
    <motor name="act_elbow_l" joint="elbow_l" gear="40" ctrlrange="-1 1"/>
    <motor name="act_elbow_r" joint="elbow_r" gear="40" ctrlrange="-1 1"/>
  </actuator>

  <contact>
    <exclude body1="torso" body2="upper_leg_l"/>
    <exclude body1="torso" body2="upper_leg_r"/>
    <exclude body1="torso" body2="upper_arm_l"/>
    <exclude body1="torso" body2="upper_arm_r"/>
    <exclude body1="upper_leg_l" body2="lower_leg_l"/>
    <exclude body1="upper_leg_r" body2="lower_leg_r"/>
    <exclude body1="lower_leg_l" body2="foot_l"/>
    <exclude body1="lower_leg_r" body2="foot_r"/>
    <exclude body1="upper_arm_l" body2="lower_arm_l"/>
    <exclude body1="upper_arm_r" body2="lower_arm_r"/>
    <exclude body1="torso" body2="head"/>
  </contact>
</mujoco>
