<!--
  SO-ARM100 MuJoCo IDO Scene
  ===========================
  Waveshare 6-DOF robotic arm with ST3215 bus servos.
  Calibrated for IDO ψ-Anchor constraints:
    - gear="50" matches 0.05 N·m stall torque
    - 5 hinge joints: Rotation / Pitch / Elbow / Wrist_Pitch / Wrist_Roll
    - Sensors: jointpos, jointvel, touch (gripper force)
    - Sentient finger bodies for ψ-Anchor biological safety

  Author: MuJoCo-Bench-IDO v0.17.0
-->
<mujoco model="so_arm100_ido">
  <compiler angle="radian" coordinate="local"/>

  <option timestep="0.002" gravity="0 0 -9.81"/>

  <default>
    <joint type="hinge" damping="0.15" armature="0.01" limited="true"/>
    <geom type="mesh" rgba="0.5 0.5 0.5 1"/>
    <motor ctrlrange="-1 1" gear="50"/>
    <position kp="120" kv="15" ctrlrange="-3.14 3.14" gear="50"/>
  </default>

  <asset>
    <!-- Arm links -->
    <mesh name="base_link" file="" scale="1 1 1"/>
    <mesh name="rotation_link" file="" scale="1 1 1"/>
    <mesh name="pitch_link" file="" scale="1 1 1"/>
    <mesh name="elbow_link" file="" scale="1 1 1"/>
    <mesh name="wrist_pitch_link" file="" scale="1 1 1"/>
    <mesh name="wrist_roll_link" file="" scale="1 1 1"/>
    <mesh name="gripper_base" file="" scale="1 1 1"/>
    <mesh name="finger_left" file="" scale="1 1 1"/>
    <mesh name="finger_right" file="" scale="1 1 1"/>

    <texture name="grid" type="2d" builtin="checker" rgb1="0.2 0.3 0.4" rgb2="0.1 0.15 0.2" width="512" height="512"/>
    <material name="grid_mat" texture="grid" texrepeat="8 8" reflectance="0.1"/>
  </asset>

  <visual>
    <headlight diffuse="0.6 0.6 0.6" ambient="0.3 0.3 0.3" specular="0 0 0"/>
    <rgba haze="0.15 0.18 0.21 1"/>
    <global azimuth="120" elevation="-20"/>
  </visual>

  <worldbody>
    <!-- Floor -->
    <geom name="floor" type="plane" size="2 2 0.1" material="grid_mat" friction="0.8 0.05 0.01"/>

    <!-- Lighting -->
    <light name="light1" pos="0.5 0.5 1.5" dir="-0.5 -0.5 -1.5" diffuse="0.8 0.8 0.8"/>
    <light name="light2" pos="-0.5 -0.5 1.5" dir="0.5 0.5 -1.5" diffuse="0.4 0.4 0.4"/>

    <!-- Table surface -->
    <body name="table" pos="0 0 0">
      <geom name="table_top" type="box" size="0.3 0.3 0.01" pos="0 0 0.4" rgba="0.4 0.3 0.2 1"/>
      <geom name="table_leg1" type="box" size="0.02 0.02 0.2" pos="0.28 0.28 0.2" rgba="0.4 0.3 0.2 1"/>
      <geom name="table_leg2" type="box" size="0.02 0.02 0.2" pos="-0.28 0.28 0.2" rgba="0.4 0.3 0.2 1"/>
      <geom name="table_leg3" type="box" size="0.02 0.02 0.2" pos="0.28 -0.28 0.2" rgba="0.4 0.3 0.2 1"/>
      <geom name="table_leg4" type="box" size="0.02 0.02 0.2" pos="-0.28 -0.28 0.2" rgba="0.4 0.3 0.2 1"/>
    </body>

    <!-- SO-ARM100 Robot Arm -->
    <body name="arm_base" pos="0 0 0.41">
      <!-- Base mount (fixed to table) -->
      <geom name="base_geom" type="cylinder" size="0.04 0.02" rgba="0.2 0.2 0.2 1"/>

      <!-- Joint 1: Rotation (base yaw) -->
      <body name="rotation_link" pos="0 0 0.02">
        <joint name="Rotation" type="hinge" axis="0 0 1" range="-3.14 3.14"/>
        <geom name="rotation_geom" type="cylinder" size="0.035 0.03" pos="0 0 0.03" rgba="0.3 0.3 0.35 1"/>

        <!-- Joint 2: Pitch (shoulder) -->
        <body name="pitch_link" pos="0 0 0.06">
          <joint name="Pitch" type="hinge" axis="0 1 0" range="-1.57 1.57"/>
          <geom name="pitch_geom" type="box" size="0.02 0.03 0.07" pos="0 0 0.04" rgba="0.35 0.35 0.4 1"/>

          <!-- Joint 3: Elbow -->
          <body name="elbow_link" pos="0 0 0.11">
            <joint name="Elbow" type="hinge" axis="0 1 0" range="-1.57 1.57"/>
            <geom name="elbow_geom" type="box" size="0.02 0.025 0.07" pos="0 0 0.04" rgba="0.4 0.4 0.45 1"/>

            <!-- Joint 4: Wrist Pitch -->
            <body name="wrist_pitch_link" pos="0 0 0.11">
              <joint name="Wrist_Pitch" type="hinge" axis="0 1 0" range="-1.57 1.57"/>
              <geom name="wrist_pitch_geom" type="box" size="0.015 0.02 0.04" pos="0 0 0.02" rgba="0.45 0.45 0.5 1"/>

              <!-- Joint 5: Wrist Roll -->
              <body name="wrist_roll_link" pos="0 0 0.05">
                <joint name="Wrist_Roll" type="hinge" axis="0 0 1" range="-3.14 3.14"/>
                <geom name="wrist_roll_geom" type="cylinder" size="0.015 0.02" rgba="0.5 0.5 0.55 1"/>

                <!-- Gripper Base -->
                <body name="gripper_base" pos="0 0 0.03">
                  <geom name="gripper_base_geom" type="box" size="0.02 0.03 0.01" rgba="0.3 0.3 0.3 1"/>

                  <!-- Left Finger (sentient) -->
                  <body name="finger_left" pos="0.015 0 0.01">
                    <joint name="Gripper_Left" type="hinge" axis="0 1 0" range="-0.5 0.5"/>
                    <geom name="finger_left_geom" type="capsule" fromto="0 0 0 0 0 0.04" size="0.005" rgba="0.8 0.6 0.4 1"/>
                    <site name="touch_left" type="sphere" size="0.006" pos="0 0 0.04" rgba="0.9 0.7 0.5 0.5"/>
                  </body>

                  <!-- Right Finger (sentient) -->
                  <body name="finger_right" pos="-0.015 0 0.01">
                    <joint name="Gripper_Right" type="hinge" axis="0 1 0" range="-0.5 0.5"/>
                    <geom name="finger_right_geom" type="capsule" fromto="0 0 0 0 0 0.04" size="0.005" rgba="0.8 0.6 0.4 1"/>
                    <site name="touch_right" type="sphere" size="0.006" pos="0 0 0.04" rgba="0.9 0.7 0.5 0.5"/>
                  </body>
                </body>
              </body>
            </body>
          </body>
        </body>
      </body>
    </body>

    <!-- Target cube for pick-and-place -->
    <body name="target_cube" pos="0.15 0 0.41">
      <freejoint/>
      <geom name="cube_geom" type="box" size="0.02 0.02 0.02" rgba="0.9 0.2 0.2 1" friction="1.0 0.05 0.01"/>
    </body>

    <!-- Goal position marker -->
    <body name="goal_marker" pos="-0.15 0.1 0.41">
      <geom name="goal_geom" type="box" size="0.025 0.025 0.005" rgba="0.1 0.9 0.1 0.3"/>
    </body>

    <!-- Camera -->
    <camera name="front_cam" pos="0.5 -0.5 0.8" quat="0.5 0.5 0.5 0.5" fovy="45"/>
    <camera name="side_cam" pos="0.6 0 0.5" quat="0.7 0 0.7 0" fovy="45"/>
    <camera name="top_cam" pos="0 0 1.0" quat="0 0 0 1" fovy="45"/>
  </worldbody>

  <!-- Actuators: ST3215 servos (gear=50 matches 0.05 N·m) -->
  <actuator>
    <position name="Rotation"     joint="Rotation"     kp="120" kv="15" ctrlrange="-3.14 3.14" gear="50"/>
    <position name="Pitch"        joint="Pitch"         kp="120" kv="15" ctrlrange="-1.57 1.57" gear="50"/>
    <position name="Elbow"        joint="Elbow"         kp="100" kv="12" ctrlrange="-1.57 1.57" gear="50"/>
    <position name="Wrist_Pitch"  joint="Wrist_Pitch"   kp="80"  kv="10" ctrlrange="-1.57 1.57" gear="50"/>
    <position name="Wrist_Roll"   joint="Wrist_Roll"    kp="80"  kv="10" ctrlrange="-3.14 3.14" gear="50"/>
    <position name="Gripper_Left"  joint="Gripper_Left"  kp="50"  kv="8"  ctrlrange="-0.5 0.5"   gear="30"/>
    <position name="Gripper_Right" joint="Gripper_Right" kp="50"  kv="8"  ctrlrange="-0.5 0.5"   gear="30"/>
  </actuator>

  <!-- Sensors -->
  <sensor>
    <!-- Joint positions -->
    <jointpos name="jp_Rotation"     joint="Rotation"/>
    <jointpos name="jp_Pitch"        joint="Pitch"/>
    <jointpos name="jp_Elbow"        joint="Elbow"/>
    <jointpos name="jp_Wrist_Pitch"  joint="Wrist_Pitch"/>
    <jointpos name="jp_Wrist_Roll"   joint="Wrist_Roll"/>
    <jointpos name="jp_Gripper_Left"  joint="Gripper_Left"/>
    <jointpos name="jp_Gripper_Right" joint="Gripper_Right"/>

    <!-- Joint velocities -->
    <jointvel name="jv_Rotation"     joint="Rotation"/>
    <jointvel name="jv_Pitch"        joint="Pitch"/>
    <jointvel name="jv_Elbow"        joint="Elbow"/>
    <jointvel name="jv_Wrist_Pitch"  joint="Wrist_Pitch"/>
    <jointvel name="jv_Wrist_Roll"   joint="Wrist_Roll"/>
    <jointvel name="jv_Gripper_Left"  joint="Gripper_Left"/>
    <jointvel name="jv_Gripper_Right" joint="Gripper_Right"/>

    <!-- Touch sensors (sentient finger) -->
    <touch name="touch_left" site="touch_left"/>
    <touch name="touch_right" site="touch_right"/>
  </sensor>

  <!-- Exclusions: prevent self-collision at gripper -->
  <contact>
    <pair geom1="finger_left_geom" geom2="finger_right_geom"/>
    <pair geom1="gripper_base_geom" geom2="finger_left_geom"/>
    <pair geom1="gripper_base_geom" geom2="finger_right_geom"/>
  </contact>
</mujoco>
